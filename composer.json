{
    "name": "appnave/nave-vendas-iss",
    "description": "This is my package iss-vendas",
    "keywords": [
        "bildvitta",
        "laravel",
        "iss-vendas",
        "vendas"
    ],
    "homepage": "https://github.com/appnave/nave-vendas-iss",
    "license": "MIT",
    "authors": [
        {
            "name": "App Nave",
            "email": "contato@nave.app.br",
            "role": "Owner"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "bildvitta/sp-produto": "^0.1",
        "spatie/laravel-package-tools": "^1.9.2"
    },
    "require-dev": {
        "nunomaduro/collision": "^8.1.1||^7.10.0",
        "larastan/larastan": "^2.9",
        "orchestra/testbench": "^9.0.0||^8.22.0",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-arch": "^2.7",
        "pestphp/pest-plugin-laravel": "^2.3",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^1.1",
        "phpstan/phpstan-phpunit": "^1.3",
        "spatie/laravel-ray": "^1.35",
        "friendsofphp/php-cs-fixer": "^3.1",
        "laravel/pint": "^1.14"
    },
    "autoload": {
        "psr-4": {
            "Bildvitta\\IssVendas\\": "src",
            "Bildvitta\\IssVendas\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bildvitta\\IssVendas\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest coverage",
        "check-style": [
            "vendor/bin/pint --test"
        ],
        "fix-style": [
            "vendor/bin/pint --parallel"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bildvitta\\IssVendas\\IssVendasServiceProvider"
            ],
            "aliases": {
                "vendas": "Bildvitta\\IssVendas\\Facades\\IssVendas"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}